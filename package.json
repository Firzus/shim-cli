{
  "name": "cursor-relay",
  "version": "0.1.0",
  "description": "Multi-provider (Codex + Claude) OpenAI-compatible proxy for Cursor BYOK, with a TUI control panel.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cursor-relay": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "serve": "bun run src/index.ts serve",
    "dev": "bun --watch run src/index.ts serve",
    "tui": "bun run src/index.ts tui",
    "up": "bun run src/index.ts up",
    "down": "bun run src/index.ts down",
    "status": "bun run src/index.ts status",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck"
  },
  "keywords": ["cli", "bun", "openai", "anthropic", "claude", "codex", "cursor", "proxy", "cloudflare-tunnel"],
  "files": ["src", "README.md"],
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@opentui/core": "0.3.4",
    "cloudflared": "^0.7.1",
    "picocolors": "^1.1.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
